<div class="welcome-card actionable" id="welcomeCard" role="button" tabindex="0" aria-label="First-time hint: open profile settings">
    <div class="badge">New</div>
    <div>
        <h3>First-time hint</h3>
        <p>Welcome to the TA recruitment workspace—this build focuses on layout, settings entry, and modal shells.</p>
        <button class="hint hint-link" id="welcomeProfileHint" type="button">Start from the profile & settings entry on the top right</button>
    </div>
</div>
